---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import profile from "../assets/profile.jpg";

const posts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="bio">
				<div class="bio-row">
					<Image src={profile} alt="Leonardo Caparica" class="avatar" width={96} height={96} />
					<div>
						<h1 class="name">{SITE_TITLE}</h1>
						<p class="subtitle">{SITE_DESCRIPTION}</p>
					</div>
				</div>
				<p>
					Desenvolvedor fullstack, Paraná. Backend é meu xodó —
					Laravel, PHP, PostgreSQL. Trabalho na <a href="https://governize.com.br" target="_blank">Governize</a>
					e estudo CC na <a href="https://www.unicentro.br/" target="_blank">UNICENTRO</a>.
				</p>
				<p>
					Aqui escrevo sobre o que aprendo, construo e penso — código,
					arquitetura, e o que mais aparecer. Tipo LinkedIn, só que mais pessoal.
				</p>
				<div class="links-row">
					<a href="/about">about</a>
					<a href="/projects">projects</a>
					<a href="/blog">posts</a>
				</div>
			</section>

			<hr />

			<section class="recent-posts">
				<h2>// posts recentes</h2>
				<div class="post-list">
					{
						posts.map((post) => (
							<article>
								<a href={`/blog/${post.id}/`}>
									<span class="post-date">
										{post.data.pubDate.toLocaleDateString(
											"en-us",
											{
												year: "numeric",
												month: "short",
												day: "numeric",
											},
										)}
									</span>
									<span class="post-title">
										{post.data.title}
									</span>
								</a>
							</article>
						))
					}
				</div>
				<a href="/blog" class="all-link">ver todos &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.bio {
		margin-bottom: 2em;
	}
	.bio-row {
		display: flex;
		align-items: center;
		gap: 1.25em;
		margin-bottom: 1.25em;
	}
	.avatar {
		border-radius: 50%;
		border: 2px solid var(--border);
		flex-shrink: 0;
		object-fit: cover;
		object-position: center;
	}
	.name {
		font-size: 1.4em;
		margin-bottom: 0.25em;
	}
	.subtitle {
		color: var(--accent);
		font-size: 0.95em;
		margin-bottom: 0;
	}
	.links-row {
		display: flex;
		gap: 1.25em;
		margin-top: 1.5em;
	}
	.links-row a {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--fg-dim);
	}
	.links-row a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.recent-posts h2 {
		font-size: 0.9em;
		color: var(--fg-dim);
		font-weight: 400;
		margin-bottom: 1em;
	}

	.post-list article {
		border-bottom: 1px solid var(--border);
	}
	.post-list a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.75em 0;
		color: var(--fg);
		text-decoration: none;
		transition: color 0.15s;
	}
	.post-list a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.85em;
		color: var(--fg-dim);
		flex-shrink: 0;
	}
	.post-list a:hover .post-date {
		color: var(--accent-dim);
	}
	.post-title {
		font-family: var(--font-mono);
		font-size: 0.95em;
		text-align: right;
	}
	.all-link {
		display: inline-block;
		margin-top: 1em;
		font-family: var(--font-mono);
		font-size: 0.85em;
		color: var(--fg-dim);
	}
	.all-link:hover {
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 720px) {
		.post-list a {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25em;
		}
		.post-title {
			text-align: left;
		}
	}
</style>