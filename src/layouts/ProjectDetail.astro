---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'projects'>['data'];

const { title, description, stack, githubLink, featured } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} / projects / ~/leonardo`} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="project-header">
					<div class="project-headline">
						<h1>{featured ? `⭐ ${title}` : title}</h1>
						{githubLink && githubLink !== '#' && (
							<a href={githubLink} target="_blank" class="github-link">GitHub &rarr;</a>
						)}
					</div>
					<p class="project-desc">{description}</p>
					<div class="project-stack">
						{stack.map((tech) => <span class="tech">{tech}</span>)}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	.project-header {
		margin-bottom: 2.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--border);
	}
	.project-headline {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		margin-bottom: 0.5em;
	}
	.project-headline h1 {
		margin: 0;
		font-size: 1.75em;
		line-height: 1.3;
	}
	.github-link {
		font-family: var(--font-mono);
		font-size: 0.85em;
		color: var(--fg-dim);
		white-space: nowrap;
	}
	.github-link:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.project-desc {
		font-family: var(--font-mono);
		font-size: 0.95em;
		color: var(--fg-dim);
		margin: 0 0 1em 0;
		line-height: 1.5;
	}
	.project-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.tech {
		font-family: var(--font-mono);
		font-size: 0.8em;
		padding: 0.2em 0.6em;
		border: 1px solid var(--border);
		color: var(--fg-dim);
	}
</style>
