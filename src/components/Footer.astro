---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Leonardo Caparica</p>
	<p class="email">leobcalmeida@gmail.com</p>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2em 0 4em;
		text-align: center;
	}
	footer p {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--fg-dim);
	}
	.email {
		margin-top: 0.5em;
	}
	.email:hover {
		color: var(--accent);
	}
</style>
