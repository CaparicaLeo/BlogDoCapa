---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="prompt">
			<span class="prompt-user">&#x7e;</span>
			<span class="prompt-sep">/</span>
			<span class="prompt-dir">leonardo</span>
			<span class="prompt-cursor">&block;</span>
		</a>
		<div class="links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/blog">posts</HeaderLink>
			<HeaderLink href="/projects">projects</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		border-bottom: 1px solid var(--border);
		padding: 1em 0;
	}
	nav {
		width: 640px;
		max-width: calc(100% - 3em);
		margin: 0 auto;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
	}
	.prompt {
		font-family: var(--font-mono);
		font-size: 1.1em;
		color: var(--fg-dim);
		display: flex;
		align-items: baseline;
		gap: 0;
		text-decoration: none;
	}
	.prompt-user {
		color: var(--accent);
	}
	.prompt-dir {
		color: var(--fg);
		font-weight: 400;
	}
	.prompt-cursor {
		margin-left: 0.15em;
		color: var(--accent);
		animation: blink 1s step-end infinite;
		font-size: 0.85em;
		line-height: 1;
	}
	@keyframes blink {
		50% { opacity: 0; }
	}
	.links {
		display: flex;
		gap: 1.25em;
	}
	.links a {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--fg-dim);
		text-decoration: none;
		transition: color 0.15s;
	}
	.links a:hover,
	.links a.active {
		color: var(--accent);
		text-decoration: none;
	}
	@media (max-width: 720px) {
		nav { flex-direction: column; align-items: flex-start; gap: 0.5em; }
	}
</style>
